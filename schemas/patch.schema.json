{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bruceoberg/jx-3p-patches/schemas/patch.schema.json",
  "title": "JX-3P Patch",
  "description": "A single Roland JX-3P patch (26 raw bytes, decoded into named fields).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dco1_range", "dco1_waveform", "dco1_fmod_lfo", "dco1_fmod_env",
    "dco2_range", "dco2_waveform", "dco2_crossmod", "dco2_tune",
    "dco2_fine_tune", "dco2_fmod_lfo", "dco2_fmod_env",
    "dco_lfo_amount", "dco_env_amount", "dco_env_polarity",
    "vcf_mix", "vcf_hpf", "vcf_cutoff", "vcf_lfo_mod", "vcf_pitch_follow",
    "vcf_resonance", "vcf_env_mod", "vcf_env_polarity",
    "vca_mode", "vca_level",
    "chorus", "lfo_waveform", "lfo_delay", "lfo_rate",
    "env_attack", "env_decay", "env_sustain", "env_release",
    "mystery"
  ],
  "properties": {
    "_patch_name": {
      "description": "Optional human-readable name (not part of the original JX-3P format).",
      "type": "string"
    },
    "dco1_range": {
      "description": "A01 DCO-1 range.",
      "type": "string",
      "enum": ["16'", "8'", "4'"]
    },
    "dco1_waveform": {
      "description": "A02 DCO-1 waveform.",
      "type": "string",
      "enum": ["saw", "pulse", "square"]
    },
    "dco1_fmod_lfo": {
      "description": "A03 DCO-1 LFO Mod (true = on). CSV: 0/1.",
      "type": "boolean"
    },
    "dco1_fmod_env": {
      "description": "A04 DCO-1 ENV Mod (true = on). CSV: 0/1.",
      "type": "boolean"
    },
    "dco2_range": {
      "description": "A05 DCO-2 range.",
      "type": "string",
      "enum": ["16'", "8'", "4'"]
    },
    "dco2_waveform": {
      "description": "A06 DCO-2 waveform.",
      "type": "string",
      "enum": ["saw", "pulse", "square", "noise"]
    },
    "dco2_crossmod": {
      "description": "A07 DCO-2 cross modulation.",
      "type": "string",
      "enum": ["off", "sync", "metal"]
    },
    "dco2_tune": {
      "description": "A08 DCO-2 Tune.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "dco2_fine_tune": {
      "description": "A09 DCO-2 Fine Tune.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "dco2_fmod_lfo": {
      "description": "A10 DCO-2 LFO Mod (true = on). CSV: 0/1.",
      "type": "boolean"
    },
    "dco2_fmod_env": {
      "description": "A11 DCO-2 ENV Mod (true = on). CSV: 0/1.",
      "type": "boolean"
    },
    "dco_lfo_amount": {
      "description": "A12 DCO LFO Mod amount.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "dco_env_amount": {
      "description": "A13 DCO ENV Mod amount.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "dco_env_polarity": {
      "description": "A14 DCO ENV polarity.",
      "type": "string",
      "enum": ["neg", "pos"]
    },
    "vcf_mix": {
      "description": "A15 VCF Mix.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "vcf_hpf": {
      "description": "A16 VCF High Pass.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "vcf_cutoff": {
      "description": "B01 VCF Cutoff Frequency.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "vcf_lfo_mod": {
      "description": "B02 VCF LFO Mod.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "vcf_pitch_follow": {
      "description": "B03 VCF Pitch Follow.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "vcf_resonance": {
      "description": "B04 VCF Resonance.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "vcf_env_mod": {
      "description": "B05 VCF ENV Mod.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "vcf_env_polarity": {
      "description": "B06 VCF ENV polarity.",
      "type": "string",
      "enum": ["neg", "pos"]
    },
    "vca_mode": {
      "description": "B07 VCA Mode.",
      "type": "string",
      "enum": ["gate", "env"]
    },
    "vca_level": {
      "description": "B08 VCA Level.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "chorus": {
      "description": "B09 Chorus (true = on). CSV: on/off.",
      "type": "boolean"
    },
    "lfo_waveform": {
      "description": "B10 LFO Waveform.",
      "type": "string",
      "enum": ["sine", "square", "random", "fast random"]
    },
    "lfo_delay": {
      "description": "B11 LFO Delay.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "lfo_rate": {
      "description": "B12 LFO Rate.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "env_attack": {
      "description": "B13 ENV Attack.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "env_decay": {
      "description": "B14 ENV Decay.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "env_sustain": {
      "description": "B15 ENV Sustain.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "env_release": {
      "description": "B16 ENV Release.",
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "mystery": {
      "description": "Byte 6 bits 4-7. Purpose unknown; must be preserved for the JX-3P verify function.",
      "type": "integer",
      "minimum": 0,
      "maximum": 15
    }
  }
}
